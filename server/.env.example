# NEPSE API
NEPSE_BASE_URL=https://www.nepalstock.com
NEPSE_VERIFY_SSL=false

# Logging
LOG_LEVEL=INFO

# Cache TTLs (seconds)
CACHE_TTL_DEFAULT=600
CACHE_TTL_LIVE=30

# Rate limiting
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_LIVE=120/minute
RATE_LIMIT_HEALTH=200/minute

# PostgreSQL
# For Docker: use service name 'postgres' as host
# For local: use 'localhost'
DATABASE_URL=postgresql+asyncpg://nepse:nepse@localhost:5432/nepse_db
